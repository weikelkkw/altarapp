# ── Supabase ─────────────────────────────────────────────────────────────────
# Create a new project at https://supabase.com, then copy these from
# Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ── Bible API ─────────────────────────────────────────────────────────────────
# Get a free key at https://scripture.api.bible
BIBLE_API_KEY=your-bible-api-key

# ── Anthropic (Claude AI) ─────────────────────────────────────────────────────
# Get a key at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# ── ElevenLabs (Text-to-Speech) ───────────────────────────────────────────────
# Get a key at https://elevenlabs.io
ELEVENLABS_API_KEY=sk_...

# ── Mapbox (Bible Maps) ───────────────────────────────────────────────────────
# Get tokens at https://account.mapbox.com/access-tokens
# NEXT_PUBLIC_ prefix means this token is exposed in the browser — use a
# restricted token scoped to tile reads only.
NEXT_PUBLIC_MAPBOX_TOKEN=pk.eyJ1...
MAPBOX_SECRET_TOKEN=sk.eyJ1...

# ── Spotify (optional — worship music integration) ────────────────────────────
# Register your app at https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=your-spotify-client-id
SPOTIFY_CLIENT_SECRET=your-spotify-client-secret

# ── App URL ───────────────────────────────────────────────────────────────────
# Used for metadata / OG tags. In dev this can be http://localhost:3001
NEXT_PUBLIC_APP_URL=https://traceapp.com
